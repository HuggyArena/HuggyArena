{
  "name": "@arena/agent",
  "private": true,
  "version": "0.1.0",
  "description": "Clawdius — Bedrock-powered operator agent for HuggyArena prediction markets (CLI + stdio MCP server).",
  "bin": {
    "arena-agent": "bin/agent"
  },
  "main": "dist/cli/index.js",
  "files": [
    "bin",
    "dist",
    "data",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp-server/index.ts",
    "chat": "tsx src/cli/index.ts chat",
    "list-models": "tsx src/cli/index.ts list-models",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.712.0",
    "@aws-sdk/client-bedrock": "^3.712.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
